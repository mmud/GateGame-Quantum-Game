# This .gitignore file should be placed at the root of your Unity project

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta

# Uncomment if you don't want to track asset meta files
# *.meta

# Autogenerated VS/VSCode files
.vs/
.vscode/
.idea/
.gradle/

# Visual Studio cache
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Rider
*.sln.iml

# Crash reports
sysinfo.txt

# Unity generated
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Addressables
ServerData/

# Android
*.apk
*.aab

# iOS
DerivedData/

# Build outputs
*.app
*.exe
*.unitypackage

# JetBrains Rider
.idea/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini